<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Dependent Picklist Pair</masterLabel>
    <description>Reusable parent/child picklist pair whose child options filter on the parent selection, sourced from Custom Metadata or a JS map.</description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__RecordPage,lightning__HomePage">
            <property
                name="grouping"
                type="String"
                label="Grouping (Custom Metadata)"
                description="Dependent_Picklist_Mapping__mdt Grouping__c value that supplies the options."
            />
            <property name="parentLabel" type="String" label="Parent Label" default="Parent" />
            <property name="childLabel" type="String" label="Child Label" default="Child" />
            <property
                name="parentPlaceholder"
                type="String"
                label="Parent Placeholder"
                default="Select an option"
            />
            <property
                name="childPlaceholder"
                type="String"
                label="Child Placeholder"
                default="Select an option"
            />
            <property name="required" type="Boolean" label="Required" default="false" />
            <property name="disabled" type="Boolean" label="Disabled" default="false" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
